{
  "manifest_version": 3,
  "name": "JobShield AI",
  "version": "1.0.0",
  "description": "Identify fake jobs and recruitment scams directly on LinkedIn, Indeed, and Gmail.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
